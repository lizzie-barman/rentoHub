<% layout("/layouts/boilerplate") %>

<div class="container mt-4">
    <div class="text-center mb-4"> <h2 class="fw-bold"><%= listing.title %></h2></div>
    <div class="row justify-content-center">
        <div class="card col-lg-7 col-md-9 show-card">
            <p class="listing-owner">Hosted by @<%= listing.owner.username %></p>
            <img src="<%= listing.image.url %>" class="card-img-top show-pg" alt="No image provided">
            <div class="card-body"> <p class="listing-description"><%= listing.description %></p>
                <p class="listing-details">₹ <%= listing.price.toLocaleString("en-IN") %> / month</p>
                <p class="listing-location"> <i class="fa-solid fa-location-dot"></i><%= listing.location %>, <%= listing.country %></p>
            </div>

        </div>
    </div>
    <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
        <div class="d-flex justify-content-center gap-3 mt-4 mb-5">
            <form method="GET" action="/listings/<%= listing.id %>/edit">
                <button class="btn btn-dark px-4 rounded-pill">Edit</button>
            </form>

            <form method="POST" action="/listings/<%= listing.id %>?_method=DELETE">
                <button class="btn btn-outline-dark px-4 rounded-pill">Delete</button>
            </form>
        </div>
    <% } %>
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <% if(currUser) { %>
                <hr class="my-4">
                    <h4 class="mb-3 fw-semibold">Add Review</h4>

                <form class="needs-validation" action="/listings/<%= listing.id %>/reviews" method="POST" novalidate>
                    <fieldset class="starability-heart">
                        <input type="radio" id="rate5" name="review[rating]" value="5" />
                        <label for="rate5">★</label>
                        <input type="radio" id="rate4" name="review[rating]" value="4" />
                        <label for="rate4">★</label>
                        <input type="radio" id="rate3" name="review[rating]" value="3" />
                        <label for="rate3">★</label>
                        <input type="radio" id="rate2" name="review[rating]" value="2" />
                        <label for="rate2">★</label>
                        <input type="radio" id="rate1" name="review[rating]" value="1" required />
                        <label for="rate1">★</label>
                    </fieldset>
                    <div class="mb-3">
                        <textarea
                            name="review[comment]"
                            id="comment"
                            rows="5"
                            class="form-control"
                            placeholder="Tell us how you felt about this place..."
                            required
                        ></textarea>
                        <div class="invalid-feedback"> Please add a comment.</div>
                    </div>

                    <button class="btn btn-dark rounded-pill px-4">Submit</button>

                </form>
            <% } %>
            <hr class="my-5">              
            <h4 class="fw-bold mb-4">All Reviews</h4>
            <div class="row g-3">
                <% for(review of listing.reviews) { %>
                    <div class="col-md-6">
                        <div class="card review-card h-100">
                            <div class="card-body">
                                <h5 class="card-title">@<%= review.author.username %></h5>
                                <p class="starability-result">
                                    <% for(let i = 0; i < review.rating; i++) { %>
                                        ★
                                    <% } %>                                     
                                </p>
                                <p class="card-text"><%= review.comment %></p>
                                <% if(currUser && (currUser._id.equals(listing.owner._id) || currUser._id.equals(review.author._id))) { %>
                                    <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review.id %>?_method=DELETE">
                                        <button class="btn btn-sm btn-outline-dark rounded-pill mt-2"> Delete</button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

</div>