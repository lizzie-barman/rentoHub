<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-4">
        <h2><b> <%= listing.title %></b></h2>
    </div>
    <div class="card col-6 offset-3 show-card listing-card">
        <h3><b>By <%=listing.owner.username%></b></h3>
        <img src="<%=listing.image.url%>" class="card-img-top show-pg" alt="No image provided">
        <div class="card-body">
            <p class="card-text">
                <b><%=listing.description %></b><br>
                &#8377; <%=listing.price.toLocaleString("en-IN") %><br>
                <%=listing.location %><br>
                <%=listing.country %><br>  
            </p>
        </div>
    </div>
    
</div>

<% if(currUser && currUser._id.equals(listing.owner._id)) {%> <!--we used the && thingy here cuz curruser is saved through a middleware nd bychance middleware error comes so pehle se hi the error is handled. btw this if is for if its a owner only then give him option of edit delete-->
<div class=" d-flex justify-content-center gap-3 mb-5 btns-show">
        <form method="GET" action="/listings/<%=listing.id%>/edit">
            <button  class="btn btn-dark px-4">Edit here</button>
        </form>
        <form method="POST" action="/listings/<%=listing.id%>?_method=DELETE" >
            <button class="btn btn-dark px-4">Delete here</button>
        </form>
</div>
<%} %>
<div class="col-8 offset-3">
    <% if(currUser) { %>
    <hr>
    <h4>Add review</h4>
    <form class="mb-3 needs-validation" action="/listings/<%=listing.id%>/reviews" method="POST" novalidate>
        <!--<div>
            <label for="rating" class="form-label">Rating</label>
            <input type="range" class="form-range" min="1" max="5" id="rating" name="review[rating]">
        </div>-->
        <div class="mb-3 mt-1">
            <!--<label for="rating" class="form-label"></label>-->
            <fieldset class="starability-heart">
                <legend>Give stars: </legend>
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked
                    aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
        </div>
        <div class="mb-3">
            <label for="comment" class="form-label">Comments</label>
            <textarea
                name="review[comment]"
                id="comment"
                cols="30"
                rows="5"
                class="form-control"
                placeholder="tell us how you felt about this place"
                required
            ></textarea>
            <div class="invalid-feedback">Submit a comment please.</div>
        <button class="btn btn-outline-dark mt-2">Submit</button>
        </form>
        <% } %>
        <hr>

        <h4><b>All Reviews</b></h4>
        <div class="row">
            <% for(review of listing.reviews) { %>
                <div class="card col-5 mt-3 mb-3 ms-5">
                    <div class="card-body">
                        <h5 class="card-title mt-2">@<%= review.author.username%></h5>
                        <p class="starability-result" data-rating="<%= review.rating %>">Rated: <%= review.rating %> stars</p>
                        <p class="card-text">  <%= review.comment %> </p>
                    </div>
                    <%if(currUser && (currUser._id.equals(listing.owner._id) || currUser._id.equals(review.author._id))) { %>
                    <form method="POST" action="/listings/<%= listing._id%>/reviews/<%=review.id%>?_method=DELETE">
                        <button class="btn btn-sm btn-dark mt-2 mb-3">
                            Delete
                        </button>
                    </form>
                    <% } %>
                </div>
            <% } %>
        </div>
        </div>
</div>