<% layout("/layouts/boilerplate") %>
    <div class="row mt-3"><!--mt is bootstrap's feature margin-top-->
        <div class="col-8 offset-2"> <!--the input boxes occupy 8 spaces and due to offset-2 its in the middle-->
            <b><h3>Editing property: <%= listing.title %></b></h3>

            <form method="POST" action="/listings/<%= listing.id %>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data"> <!--novalidate used to disable browsers ui and needs-validation class is in script.js file that checks if something in the form is invalid-->
                <!--form-label and form-control classes are all bootstrap clasess used to automatically style the website's input areas proprly.-->
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input id="title" name="listing[title]" value="<%= listing.title %>" type="text" class="form-control" required>
                    <div class="valid-feedback">Title looks good!</div>
                    <div class="invalid-feedback">Title can't be blank.</div>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea id="description" name="listing[description]" class="form-control" required><%= listing.description %></textarea>
                    <div class="valid-feedback">Good description!</div>
                    <div class="invalid-feedback">Short description should be provided.</div>
                </div>

                <div class="mb-3">
                    <label for="image" class="form-label">Image</label>
                    <input id="image" name="listing[image]" type="file" class="form-control"
                        placeholder="Enter image URL">
                </div>

                <div class="row mb-3">
                    <div class="col-md-5">
                        <label for="price" class="form-label">Price</label>
                        <input id="price" name="listing[price]"  value="<%= listing.price %>" class="form-control" required>
                        <div class="invalid-feedback">Please enter a valid price.</div>
                    </div>
                    
                    <div class="col-md-7">
                         <label for="location" class="form-label">Location</label>
                        <input id="location" name="listing[location]" value="<%= listing.location %>" class="form-control" required>
                        <div class="invalid-feedback">Location can't be blank!</div>
                    </div>
                </div>
                

                <div class="mb-3">
                    <label for="country" class="form-label">Country</label>
                    <input id="country" name="listing[country]" value="<%= listing.country %>" class="form-control" required>
                    <div class="invalid-feedback">Country name can't be blank!</div>
                </div>

                <button type="submit" class="btn btn-dark edit-btn mb-3">Edit Listing</button>
                <!-- btn btn-dark these are also bootstrap classes only-->
            </form>
        </div>
    </div>